    {
      "name": "Email Notifications",
      "item": [
        {
          "name": "Send Raw Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Cookie",
                "value": "{{bffCookie}}",
                "type": "text"
              },
              {
                "key": "X-CSRF",
                "value": "{{xcsrfToken}}",
                "type": "text"
              } 
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"to\": \"recipient@example.com\",\n  \"subject\": \"Email Subject\",\n  \"rawContent\": \"<html><body>Email HTML content</body></html>\"\n}"
            },
            "url": {
              "raw": "{{bff_base_url}}/api/v1/notification/email/send/raw",
              "host": [
                "{{bff_base_url}}"
              ],
              "path": [
                "api",
                "notification",
                "email",
                "send",
                "raw"
              ]
            },
            "description": "Send raw email notification with HTML content"
          }
        },
